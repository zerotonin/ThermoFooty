cff-version: 1.2.0
title: "ThermoFooty: pre-registered natural-experiment test of the heat-aggression hypothesis on European soccer"
message: "If you use this software, please cite both the software (this entry) and the underlying pre-registration (OSF DOI in references below)."
type: software
version: "0.1.0-dev0"
date-released: "2026-05-26"
license: MIT
url: "https://github.com/zerotonin/ThermoFooty"
repository-code: "https://github.com/zerotonin/ThermoFooty"
authors:
  - family-names: Geurten
    given-names: "Bart R.H."
    orcid: "https://orcid.org/0000-0002-1816-3241"
